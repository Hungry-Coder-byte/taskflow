{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "A web application for managing tasks and projects with user authentication and drag-and-drop functionality.",
  "main": "backend/src/index.ts",
  "scripts": {
    "start:backend": "node backend/src/index.ts",
    "start:frontend": "vite",
    "dev:backend": "nodemon backend/src/index.ts",
    "build:backend": "tsc --build",
    "dev:frontend": "vite",
    "preview:frontend": "vite preview",
    "db:data": "mongod --dbpath ./data"
  },
  "keywords": [
    "react",
    "vite",
    "typescript",
    "tailwind",
    "express",
    "mongodb",
    "task management",
    "project management"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^20.8.0",
    "bcryptjs": "^2.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.7.0",
    "zod": "^3.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.0.0",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/express": "^4.17.18",
    "@types/mongoose": "^0.0.0",
    "@types/node": "^20.8.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "vite": "^4.4.2"
  },
  "private": true
