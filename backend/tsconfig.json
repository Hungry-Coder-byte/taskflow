{
  "compilerOptions": {
    "target": "ES2020",
    "moduleResolution": "Node",
    "module": "CommonJS",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["src/*"]
    },
    "types": [
      "node"
    ]
  }
}